{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://deepflow/schemas/validate-result.schema.json",
  "title": "ValidateResult",
  "description": "Output of df-artifact-validate.js. Drift block, when present, has frozen keys consumed by df-spike-validate.js REQ-4.",
  "type": "object",
  "properties": {
    "spec": { "type": "string" },
    "artifact": { "type": "string" },
    "rows": { "type": "array" },
    "drift": {
      "type": "object",
      "required": ["jaccard_below", "out_of_scope_count", "likely_files_coverage_pct"],
      "properties": {
        "jaccard_below": { "type": "number" },
        "out_of_scope_count": { "type": "integer" },
        "likely_files_coverage_pct": { "type": "number" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
